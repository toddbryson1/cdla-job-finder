DATABASE_URL=postgres://USER@localhost:5432/cdla_dev

# Stytch — magic link auth for the matches page
# Get these from https://stytch.com -> your project -> API Keys
# Register the magic-link redirect URL `http://localhost:3000/authenticate`
# (and the production equivalent) in the Stytch dashboard.
STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_PUBLIC_TOKEN=
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=

# Public base URL — used to build the magic-link redirect.
# Defaults to http://localhost:3000 in dev; set to https://cdla.jobs in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000
