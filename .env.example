DATABASE_URL=postgres://USER@localhost:5432/cdla_dev

# Stytch — magic link auth for the matches page
# Get these from https://stytch.com -> your project -> API Keys
# Register the magic-link redirect URL `http://localhost:3000/authenticate`
# (and the production equivalent) in the Stytch dashboard.
STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_PUBLIC_TOKEN=
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=

# Public base URL — used to build the magic-link redirect.
# Defaults to http://localhost:3000 in dev; set to https://cdla.jobs in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GoHighLevel — inbound webhook URL for the /partners/brief carrier lead form.
# Optional once the direct-API path below is configured. Kept as a fallback.
GHL_CARRIER_LEAD_WEBHOOK_URL=

# GoHighLevel Private Integration token — scopes: contacts.write,
# locations/tags.write, conversations/message.write. Settings ->
# Private Integrations -> Create. Never paste in chat or commit to git.
GHL_API_TOKEN=

# GoHighLevel sub-account location ID. Settings -> Business Profile,
# or copy from any GHL URL containing /location/<id>/.
GHL_LOCATION_ID=

# Public URL of the carrier brief PDF. Upload the PDF to GHL Media Library
# (Marketing -> Media) and paste the returned URL here, or self-host at a
# stable public URL. If blank, the email sends without an attachment.
GHL_BRIEF_PDF_URL=
